# Environment variables for MiniQR

# Crowdin configuration for translations
CROWDIN_PERSONAL_TOKEN="your_personal_token"
CROWDIN_PROJECT_ID="your_project_id"

# Base path for deployment (e.g., /mini-qr for deploying at domain.com/mini-qr)
# Default: ./ (relative paths, works at any sub-path without configuration)
BASE_PATH=/mini-qr

VITE_HIDE_CREDITS=false
VITE_DEFAULT_PRESET=plain
VITE_DEFAULT_DATA_TO_ENCODE=
VITE_QR_CODE_PRESETS=
VITE_FRAME_PRESET=
VITE_FRAME_PRESETS=
VITE_DISABLE_LOCAL_STORAGE=false
VITE_ENABLE_ANALYTICS=false

# --- HTTP API settings ---
# Leave API_KEY blank to keep the API open. When set, callers must send either
# "Authorization: Bearer <key>" or "X-API-Key: <key>" on all /api/* requests
# (except /api/health and /api/docs).
API_KEY=

# Where saved QR codes are persisted. Mount a volume to this path in Docker
# to keep files across container restarts.
QR_STORAGE_DIR=/data/qr-files

# Per-IP rate limit applied to all /api/* routes (except /api/health and
# /api/docs).
API_RATE_LIMIT_PER_MIN=1000

# Optional: bind the API on its own port. When unset, the SPA and API share
# one port (PORT, default 8080). When set, the SPA listens on PORT and the
# API listens on API_PORT — useful for firewalling the API separately from
# the public web UI. API_HOST defaults to HOST.
# API_PORT=8081
# API_HOST=0.0.0.0

# --- Logo input ---
# Directory containing reusable logo files referenced via {"image":{"path":"..."}}.
# Leave unset to disable the feature entirely (recommended unless you need it).
# Path traversal and non-image extensions are rejected.
# LOGO_DIR=/data/logos

# Comma-separated hostnames allowed for remote logo fetches
# (image.href: "https://..."). When unset, every public hostname is allowed
# (private/loopback/link-local IPs are always blocked). Set this to lock the
# server down to a specific CDN.
# REMOTE_LOGO_HOSTS=cdn.example.com,assets.example.com
